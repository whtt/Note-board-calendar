# ==========================================
# 案头雅记 (MYCALENDAR) - 全局 Git 忽略配置
# ==========================================

# 1. 依赖包 (自动忽略所有层级的 node_modules)
node_modules/
frontend/node_modules/
backend/node_modules/

# 2. 前端构建产物
frontend/dist/
frontend/dist-ssr/
*.local

# 3. 桌面端构建与打包产物 (极其重要，体积很大！)
release/
zip/
out/
builder-debug.yml
builder-effective-config.yaml

# 4. 个人隐私数据 (极其重要！防止日记和任务传到公开网络)
backend/os_data.json
backend/os_config.json

# 5. 日志文件
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 6. 编辑器与系统生成文件
.vscode/*
frontend/.vscode/
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
